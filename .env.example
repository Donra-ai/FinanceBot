# IMPORTANTE: Este archivo es un EJEMPLO.
# Copia este contenido a tu .env local (NO en GitHub)
# En Railway, configura estas variables en la sección "Variables" del proyecto

# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_TOKEN=tu_nuevo_token_aqui

# API Key de Anthropic
ANTHROPIC_API_KEY=sk-ant-...tu_nueva_api_key_aqui

# ID de la Google Sheet (la parte larga en la URL)
# https://docs.google.com/spreadsheets/d/1ZpkumqeN9a1Q8K7m2PWR4Uv_JCmYow9sIvOvMkoqfHE/edit
# ID: 1ZpkumqeN9a1Q8K7m2PWR4Uv_JCmYow9sIvOvMkoqfHE
GOOGLE_SHEETS_ID=1ZpkumqeN9a1Q8K7m2PWR4Uv_JCmYow9sIvOvMkoqfHE

# Credenciales de Google (el contenido del JSON descargado)
# En Railway, pega TODO el contenido del JSON entre comillas
GOOGLE_SHEETS_CREDENTIALS={"type": "service_account", "project_id": "...", ...}
